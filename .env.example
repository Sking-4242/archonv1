# LLM Provider Selection
# Options: anthropic | openai | gemini | ollama | xai
LLM_PROVIDER=anthropic

# API Keys — fill in the key for your chosen provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Provider Base URLs
XAI_BASE_URL=https://api.x.ai/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# App Config
AWS_DEFAULT_REGION=us-east-1
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Archon Academy
ACADEMY_PORT=3001
VITE_ACADEMY_API_URL=http://localhost:8000

# PostgreSQL (used by Academy)
POSTGRES_DB=archon_academy
POSTGRES_USER=archon
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://archon:password@db:5432/archon_academy

# Academy JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ACADEMY_SECRET_KEY=

# archonpro.net portal (local dev)
PORTAL_PORT=3002
ARCHONPRO_PORTAL_URL=http://localhost:3002

# Email — console | postmark | sendgrid
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@archonpro.net
POSTMARK_API_KEY=
SENDGRID_API_KEY=

# Stripe (portal checkout + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_dev_test_secret
STRIPE_PRICE_INDIVIDUAL_MONTHLY=
STRIPE_PRICE_INSTITUTIONAL=

# Dev: simulate checkout without Stripe CLI
#   docker compose exec backend python simulate_stripe_checkout.py student@archon.academy
# Dev: seed institutional license for portal admin UI
#   docker compose exec backend python seed_institutional.py

# License lifecycle
LICENSE_GRACE_DAYS=7
LICENSE_REMINDER_DAYS=14
LICENSE_OFFLINE_GRACE_DAYS=7

# Open access: any logged-in user gets full product features (commerce parked).
# Self-hosted Professional still works offline without an account on the free tier.
# Legacy alias DEV_UNLOCK_ALL is still honored if ARCHON_OPEN_ACCESS is unset.
ARCHON_OPEN_ACCESS=true
DEV_UNLOCK_ALL=true

# ── Live pricing credentials (all optional) ───────────────────────────────────
# AWS: live pricing uses the public AWS Price List API — no credentials needed.
# AWS estimates are always live and require no configuration.

# GCP: if set, the estimator calls the Cloud Billing Catalog API.
# Create an API key in GCP Console → APIs & Services → Credentials,
# then enable the Cloud Billing API for your project.
GCP_BILLING_API_KEY=

# Azure pricing requires no credentials — the public Retail Prices API
# (prices.azure.com) is called automatically when estimating Azure architectures.

# Academy → Canvas integration
VITE_CANVAS_URL=http://localhost:3000
