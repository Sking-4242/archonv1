# LLM Provider Selection
# Options: anthropic | openai | gemini | ollama | xai
LLM_PROVIDER=anthropic

# API Keys — fill in the key for your chosen provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Provider Base URLs
XAI_BASE_URL=https://api.x.ai/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# App Config
AWS_DEFAULT_REGION=us-east-1
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Archon Academy
ACADEMY_PORT=3001
VITE_ACADEMY_API_URL=http://localhost:8000

# PostgreSQL (used by Academy)
POSTGRES_DB=archon_academy
POSTGRES_USER=archon
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://archon:password@db:5432/archon_academy

# Academy JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ACADEMY_SECRET_KEY=

# ── Live pricing credentials (all optional) ───────────────────────────────────
# AWS: if set, the estimator calls the AWS Pricing API for real-time prices.
# Requires pricing:GetProducts IAM permission (read-only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP: if set, the estimator calls the Cloud Billing Catalog API.
# Create an API key in GCP Console → APIs & Services → Credentials,
# then enable the Cloud Billing API for your project.
GCP_BILLING_API_KEY=

# Azure pricing requires no credentials — the public Retail Prices API
# (prices.azure.com) is called automatically when estimating Azure architectures.
